{
  "permissions": {
    "allow": [
      "Bash(cargo build*)",
      "Bash(cargo test*)",
      "Bash(cargo check*)",
      "Bash(cargo clippy*)",
      "Bash(cargo fmt*)",
      "Bash(cargo doc*)",
      "Bash(cargo run -p *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git blame*)",
      "Bash(git rev-parse*)",
      "Bash(grep*)",
      "Bash(rg*)",
      "Bash(find*)",
      "Bash(ls*)",
      "Bash(wc*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(sort*)",
      "Bash(uniq*)",
      "Bash(file*)",
      "Bash(stat*)",
      "Bash(tree*)",
      "Bash(jq*)",
      "Bash(xxd*)",
      "Bash(curl -s*)",
      "Bash(gh api*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh issue view*)",
      "Bash(gh issue list*)",
      "Bash(mkdir -p /tmp/*)",
      "Bash(./target/release/luna state*)",
      "Bash(./target/release/luna run*)",
      "Bash(./target/release/luna --help)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // empty' 2>/dev/null); case \"$f\" in *.rs) cd \"${CLAUDE_PROJECT_DIR:-.}\" || exit 0; out=$(cargo clippy --workspace --all-targets --all-features -- -D warnings 2>&1) || { printf '%s\\n' \"$out\" >&2; exit 2; } ;; esac; exit 0",
            "asyncRewake": true,
            "timeout": 300,
            "statusMessage": "clippy --all-features (rust-lint-discipline)",
            "rewakeSummary": "clippy found warnings",
            "rewakeMessage": "rust-lint-discipline hook: `cargo clippy --workspace --all-targets --all-features -- -D warnings` FAILED after your .rs edit. Fix these warnings before continuing:"
          }
        ]
      }
    ]
  }
}
