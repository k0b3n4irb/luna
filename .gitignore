# Rust build artifacts
/target
**/*.rs.bk

# Editors
*.swp
*.swo
.vscode/
.idea/
*~

# OS
.DS_Store
Thumbs.db

# GUI screenshots: default to $HOME/.local/luna/screenshots (outside the
# repo); this only catches the cwd fallback used when $HOME is unset.
/screenshots/

# Tests
# Tom Harte / SingleStepTests CPU datasets — large external shallow
# clones, fetched on demand (tools/fetch-tom-harte*.sh). Never committed.
/tests/tom-harte/
/tests/tom-harte-spc700/
# Peter Lemon SNES test ROMs (crates/luna-core/tests/snes_test_roms.rs)
# live in a SIBLING checkout `../luna_tests` (tools/fetch-snes-test-roms.sh),
# outside this repo — nothing to ignore here.
# Proprietary game ROMs — never commit.
/tests/roms/*
!/tests/roms/.gitkeep
/tests/golden/*.png
!/tests/golden/.gitkeep

# Local config
/.envrc
/.direnv
.env
.mcp.json

# Claude Code — personal overrides only; .claude/settings.json + rules/
# + commands/ are checked in.
.claude/settings.local.json
book/book/
