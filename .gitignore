# Rust build artifacts
/target
**/*.rs.bk

# Editors
*.swp
*.swo
.vscode/
.idea/
*~

# OS
.DS_Store
Thumbs.db

# GUI screenshots: default to $HOME/.local/luna/screenshots (outside the
# repo); this only catches the cwd fallback used when $HOME is unset.
/screenshots/

# Tests
# Tom Harte / SingleStepTests CPU datasets — large external shallow
# clones, fetched on demand (tools/fetch-tom-harte*.sh). Never committed.
/tests/tom-harte/
/tests/tom-harte-spc700/
# Peter Lemon SNES test ROMs — external clone, fetched on demand.
/tests/peterlemon-snes/
# Proprietary game ROMs — never commit.
/tests/roms/*
!/tests/roms/.gitkeep
/tests/golden/*.png
!/tests/golden/.gitkeep

# Local config
/.envrc
/.direnv
.env
.mcp.json

# Claude Code — personal overrides only; .claude/settings.json + rules/
# + commands/ are checked in.
.claude/settings.local.json

# Reference emulator clones (for hand-comparing against ares/Mesen2/etc.
# during reference-first investigations — not part of luna's source).
/franlmsp-snes
/ness
/pinky
/rsnes
/snes-apu
